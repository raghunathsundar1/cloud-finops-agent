# Cloud FinOps Agent - Environment Variables
# Copy this file to .env and fill in your actual values

# OpenAI API Configuration (if using OpenAI)
OPENAI_API_KEY=your-openai-api-key-here

# Hugging Face Configuration (recommended for free usage)
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct

# Hugging Face Token (alternative to OPENAI_API_KEY)
HF_TOKEN=your-huggingface-token-here

# Environment URL (where the FinOps server is running)
ENV_URL=http://localhost:7860

# Notes:
# - The inference script will use HF_TOKEN if set, otherwise OPENAI_API_KEY
# - API_BASE_URL defaults to OpenAI if not set
# - MODEL_NAME defaults to gpt-4o-mini if not set
# - ENV_URL defaults to http://localhost:7860 if not set
